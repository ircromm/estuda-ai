# Anthropic API Key (obrigatório)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelo (opcional, default: claude-sonnet-4-20250514)
MODEL=claude-sonnet-4-20250514

# CORS origins separados por vírgula (em produção, use o domínio do frontend)
ALLOWED_ORIGINS=*

# Porta (Railway injeta automaticamente)
PORT=8000
